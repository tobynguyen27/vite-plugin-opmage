{
	"compilerOptions": {
		"esModuleInterop": true,
		"skipLibCheck": true,
		"target": "esnext",
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		"resolveJsonModule": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"lib": ["es2023"],
		"types": ["node"],
		"strict": true,
		"declaration": true,
		"isolatedDeclarations": false,
		"isolatedModules": true,
		"noEmit": true,
		"plugins": [
			{
				"name": "@effect/language-service"
			}
		],

		"paths": {
			"@/*": ["./src/*"]
		}
	}
}
