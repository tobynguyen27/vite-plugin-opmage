{
	"name": "vite-plugin-opmage",
	"version": "0.0.1",
	"description": "A Vite plugin for optimizing images.",
	"keywords": [
		"vite-plugin"
	],
	"homepage": "https://github.com/tobynguyen27/vite-plugin-opmage#readme",
	"bugs": {
		"url": "https://github.com/tobynguyen27/vite-plugin-opmage/issues"
	},
	"license": "MIT",
	"author": "Toby Nguyen <hi@tobynguyen.net>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tobynguyen27/vite-plugin-opmage.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": "./dist/index.mjs",
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "vp pack",
		"dev": "vp pack --watch",
		"test": "vp test",
		"check": "vp check",
		"prepublishOnly": "vp run build",
		"prepare": "vp config",
		"bump": "bumpp"
	},
	"dependencies": {
		"effect": "catalog:prod",
		"ohash": "catalog:prod",
		"pathe": "catalog:prod",
		"picocolors": "catalog:prod",
		"pretty-bytes": "catalog:prod",
		"unstorage": "catalog:prod"
	},
	"devDependencies": {
		"@effect/language-service": "catalog:types",
		"@types/node": "catalog:types",
		"@typescript/native-preview": "catalog:types",
		"bumpp": "catalog:scripts",
		"oxlint-plugin-case-police": "catalog:lint",
		"typescript": "catalog:types",
		"vite-plus": "catalog:build"
	},
	"peerDependencies": {
		"@napi-rs/image": "catalog:dev",
		"vite": "catalog:build"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.8.0",
			"onFail": "download"
		}
	},
	"engines": {
		"node": "^22.18.0 || >=24.12.0"
	}
}
